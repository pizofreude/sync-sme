# Speechmatics API key (enables transcription in meeting pipeline)
SPEECHMATICS_API_KEY=
# Discord channel IDs for proactive bot posting (right-click channel → Copy Channel ID)
# Gap alerts: posted to this channel when unlogged task candidates are detected
